# Скопируй в .env и заполни значения.
# Этот файл — подключения и секреты.
# Всё остальное (scoring, cron, feeds и т.д.) — в config.yaml.

# ---- PostgreSQL ----------------------------------------------------
DATABASE_DSN=postgres://user:pass@localhost:5432/rss_aggregator?sslmode=disable

# ---- Telegram ------------------------------------------------------
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHANNEL_ID=-1001234567890

# ---- Elasticsearch -------------------------------------------------
ELASTICSEARCH_ADDR=http://localhost:9200

# ---- ClickHouse ----------------------------------------------------
CLICKHOUSE_DSN=clickhouse://user:pass@localhost:9000/default

# ---- Суммаризатор: локальный LLM (только если summarizer.provider=openai) ---
# Ollama:    SUMMARIZER_API_URL=http://localhost:11434/v1
# LM Studio: SUMMARIZER_API_URL=http://localhost:1234/v1
# vLLM:      SUMMARIZER_API_URL=http://localhost:8000/v1
SUMMARIZER_API_URL=http://localhost:11434/v1
SUMMARIZER_API_KEY=   # необязательно, оставить пустым для Ollama

# ---- MinIO (хранилище изображений) ---------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
